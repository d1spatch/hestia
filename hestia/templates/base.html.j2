<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}Hestia{% endblock %} - Hestia Cookbook</title>
<meta name="description" content="{% block meta_description %}Precision cookbook with recipes, ingredient intelligence, and calm kitchen-focused browsing.{% endblock %}">
<style>
  {% include "_brand.css.j2" %}
  {% include "_app.css.j2" %}
  {% block extra_style %}{% endblock %}
</style>
</head>
<body class="{% block body_class %}app-page{% endblock %}">
{% set nav_visible = show_nav if show_nav is defined else true %}
<div class="site-backdrop" aria-hidden="true">
  <div class="site-backdrop__orb site-backdrop__orb--one"></div>
  <div class="site-backdrop__orb site-backdrop__orb--two"></div>
  <div class="site-backdrop__orb site-backdrop__orb--three"></div>
</div>
{% if nav_visible %}
<header class="site-header">
  <div class="site-header__inner">
    <a class="brand-mark" href="{{ base }}">
      <span class="brand-mark__glyph">H</span>
      <span class="brand-mark__copy">
        <span class="brand-mark__kicker">Kitchen system</span>
        <span class="brand-mark__name">Hestia</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="{{ base }}">Recipes</a>
      <a href="{{ base }}ingredients/">Ingredients</a>
      <a href="{{ base }}docs/">Docs</a>
    </nav>
  </div>
</header>
{% endif %}
<main class="page-shell">
  {% block page_intro %}{% endblock %}
  <div class="content-shell">
    {% block content %}{% endblock %}
  </div>
</main>
{% if nav_visible %}
<footer class="site-footer">
  <div class="site-footer__inner">
    <div>Built for cooks who like precision without a sterile interface.</div>
    <div class="site-footer__links">
      <a href="{{ base }}">Recipe browser</a>
      <a href="{{ base }}ingredients/">Ingredient catalog</a>
      <a href="{{ base }}docs/">Documentation</a>
    </div>
  </div>
</footer>
{% endif %}
</body>
</html>

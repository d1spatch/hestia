{% extends "base.html.j2" %}

{% block title %}{{ ing.name }}{% endblock %}

{% block page_intro %}
<section class="hero hero--detail">
  <div class="hero__copy surface-card">
    <a class="back-link" href="{{ base }}ingredients/">&larr; Back to the ingredient catalog</a>
    <p class="eyebrow">Ingredient profile</p>
    <h1 class="hero__title hero__title--tight">{{ ing.name }}</h1>
    <p class="hero__lead">
      Reference nutrition, sourcing, and price history for one ingredient record in your pantry database.
    </p>
    <div class="chip-row">
      {% if ing.category %}<span class="chip chip--strong">{{ ing.category }}</span>{% endif %}
      {% if ing.aliases %}<span class="chip chip--soft">{{ ing.aliases | length }} aliases</span>{% endif %}
      {% if ing.source %}<span class="chip chip--soft">{{ ing.source.type | upper }}</span>{% endif %}
    </div>
    {% if ing.notes %}
      <div class="note-block" style="margin-top:1.2rem">{{ ing.notes }}</div>
    {% endif %}
  </div>
  <aside class="hero__rail surface-card surface-card--accent">
    <p class="eyebrow eyebrow--soft">Snapshot</p>
    <div class="metric-grid">
      <article class="metric-card">
        <span class="metric-card__label">Calories</span>
        <strong>
          {% if ing.calories_per_100g is defined and ing.calories_per_100g is not none %}
            {{ "%.0f"|format(ing.calories_per_100g) }} kcal
          {% else %}
            -
          {% endif %}
        </strong>
      </article>
      <article class="metric-card">
        <span class="metric-card__label">Protein</span>
        <strong>
          {% if ing.protein_per_100g is defined and ing.protein_per_100g is not none %}
            {{ "%.1f"|format(ing.protein_per_100g) }} g
          {% else %}
            -
          {% endif %}
        </strong>
      </article>
      <article class="metric-card">
        <span class="metric-card__label">Carbs</span>
        <strong>
          {% if ing.carbs_per_100g is defined and ing.carbs_per_100g is not none %}
            {{ "%.1f"|format(ing.carbs_per_100g) }} g
          {% else %}
            -
          {% endif %}
        </strong>
      </article>
      <article class="metric-card">
        <span class="metric-card__label">Fat</span>
        <strong>
          {% if ing.fat_per_100g is defined and ing.fat_per_100g is not none %}
            {{ "%.1f"|format(ing.fat_per_100g) }} g
          {% else %}
            -
          {% endif %}
        </strong>
      </article>
    </div>
    {% if ing.price_per_kg is defined and ing.price_per_kg is not none %}
      <p class="price-display">
        <small>{{ (ing.currency or 'USD') | csym }}</small>{{ "%.2f"|format(ing.price_per_kg) }}
        <span>/ kg</span>
      </p>
    {% else %}
      <p class="hero-note">No current price is recorded for this ingredient yet.</p>
    {% endif %}
  </aside>
</section>
{% endblock %}

{% block content %}
<div class="detail-layout">
  <section class="panel-card surface-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Nutrition facts</p>
        <h2 class="section-heading">Per 100 g reference.</h2>
      </div>
    </div>
    <table class="nutrition-table">
      <tbody>
        <tr class="major"><td>Calories</td>
          <td>{% if ing.calories_per_100g is defined and ing.calories_per_100g is not none %}{{ "%.0f"|format(ing.calories_per_100g) }} kcal{% else %}-{% endif %}</td></tr>
        <tr><td>Protein</td>
          <td>{% if ing.protein_per_100g is defined and ing.protein_per_100g is not none %}{{ "%.1f"|format(ing.protein_per_100g) }} g{% else %}-{% endif %}</td></tr>
        <tr><td>Total Fat</td>
          <td>{% if ing.fat_per_100g is defined and ing.fat_per_100g is not none %}{{ "%.1f"|format(ing.fat_per_100g) }} g{% else %}-{% endif %}</td></tr>
        {% if ing.saturated_fat_per_100g is defined and ing.saturated_fat_per_100g is not none %}
        <tr class="sub"><td>Saturated Fat</td><td>{{ "%.1f"|format(ing.saturated_fat_per_100g) }} g</td></tr>
        {% endif %}
        <tr><td>Total Carbohydrate</td>
          <td>{% if ing.carbs_per_100g is defined and ing.carbs_per_100g is not none %}{{ "%.1f"|format(ing.carbs_per_100g) }} g{% else %}-{% endif %}</td></tr>
        {% if ing.fiber_per_100g is defined and ing.fiber_per_100g is not none %}
        <tr class="sub"><td>Dietary Fiber</td><td>{{ "%.1f"|format(ing.fiber_per_100g) }} g</td></tr>
        {% endif %}
        {% if ing.sugar_per_100g is defined and ing.sugar_per_100g is not none %}
        <tr class="sub"><td>Total Sugars</td><td>{{ "%.1f"|format(ing.sugar_per_100g) }} g</td></tr>
        {% endif %}
        {% if ing.cholesterol_per_100g is defined and ing.cholesterol_per_100g is not none %}
        <tr><td>Cholesterol</td><td>{{ "%.1f"|format(ing.cholesterol_per_100g * 1000) }} mg</td></tr>
        {% endif %}
        {% if ing.sodium_per_100g is defined and ing.sodium_per_100g is not none %}
        <tr><td>Sodium</td><td>{{ "%.0f"|format(ing.sodium_per_100g * 1000) }} mg</td></tr>
        {% endif %}
        {% if ing.potassium_per_100g is defined and ing.potassium_per_100g is not none %}
        <tr><td>Potassium</td><td>{{ "%.0f"|format(ing.potassium_per_100g) }} mg</td></tr>
        {% endif %}
        {% if ing.calcium_per_100g is defined and ing.calcium_per_100g is not none %}
        <tr><td>Calcium</td><td>{{ "%.0f"|format(ing.calcium_per_100g) }} mg</td></tr>
        {% endif %}
        {% if ing.iron_per_100g is defined and ing.iron_per_100g is not none %}
        <tr><td>Iron</td><td>{{ "%.2f"|format(ing.iron_per_100g) }} mg</td></tr>
        {% endif %}
        {% if ing.magnesium_per_100g is defined and ing.magnesium_per_100g is not none %}
        <tr><td>Magnesium</td><td>{{ "%.0f"|format(ing.magnesium_per_100g) }} mg</td></tr>
        {% endif %}
        {% if ing.manganese_per_100g is defined and ing.manganese_per_100g is not none %}
        <tr><td>Manganese</td><td>{{ "%.3f"|format(ing.manganese_per_100g) }} mg</td></tr>
        {% endif %}
        {% if ing.vitamin_c_per_100g is defined and ing.vitamin_c_per_100g is not none %}
        <tr><td>Vitamin C</td><td>{{ "%.1f"|format(ing.vitamin_c_per_100g) }} mg</td></tr>
        {% endif %}
        {% if ing.vitamin_d_per_100g is defined and ing.vitamin_d_per_100g is not none %}
        <tr><td>Vitamin D</td><td>{{ "%.1f"|format(ing.vitamin_d_per_100g) }} mcg</td></tr>
        {% endif %}
        {% if ing.vitamin_k_per_100g is defined and ing.vitamin_k_per_100g is not none %}
        <tr><td>Vitamin K</td><td>{{ "%.1f"|format(ing.vitamin_k_per_100g) }} mcg</td></tr>
        {% endif %}
      </tbody>
    </table>

    {% if ing.source %}
    <p class="subtle" style="margin-top:1rem">
      Source: {{ ing.source.type | upper }}
      {% if ing.source.fdc_id %} &middot; FDC ID {{ ing.source.fdc_id }}{% endif %}
      {% if ing.source.description %} &middot; {{ ing.source.description }}{% endif %}
      {% if ing.source.retrieved %} &middot; retrieved {{ ing.source.retrieved }}{% endif %}
    </p>
    {% endif %}
  </section>

  <section class="panel-card surface-card">
    <div class="panel-card__header">
      <div>
        <p class="eyebrow">Pricing</p>
        <h2 class="section-heading">Track current cost and movement.</h2>
      </div>
    </div>
    {% if ing.price_per_kg is defined and ing.price_per_kg is not none %}
    <p class="price-display">
      <small>{{ (ing.currency or 'USD') | csym }}</small>{{ "%.2f"|format(ing.price_per_kg) }}
      <span>/ kg</span>
    </p>
    {% else %}
    <p class="subtle">No price recorded.</p>
    {% endif %}

    {% if ing.price_history and ing.price_history | length > 0 %}
    <h3 class="step-group__title" style="margin-top:1.4rem">Price history</h3>
    <table class="nutrition-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Store</th>
          <th class="align-right">Package</th>
          <th class="align-right">Net wt</th>
          <th class="align-right">Per kg</th>
        </tr>
      </thead>
      <tbody>
        {% for h in ing.price_history | reverse %}
        <tr>
          <td>{{ h.date }}</td>
          <td>{{ h.store or '-' }}</td>
          <td class="align-right mono">{% if h.package_price is defined and h.package_price is not none %}{{ (ing.currency or 'USD') | csym }}{{ "%.2f"|format(h.package_price) }}{% else %}-{% endif %}</td>
          <td class="align-right mono">{{ h.net_weight or '-' }}</td>
          <td class="align-right mono">{{ (ing.currency or 'USD') | csym }}{{ "%.4f"|format(h.price_per_kg) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    {% if ing.price_history | length > 1 %}
    <div style="margin-top:1.4rem">
      <canvas id="priceChart" height="180"></canvas>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script>
    (function() {
      var root = getComputedStyle(document.documentElement);
      var brand = root.getPropertyValue('--brand').trim();
      var accent = root.getPropertyValue('--accent').trim();
      var history = {{ ing.price_history | tojson }};
      var labels = history.map(function(h) { return h.date; });
      var prices = history.map(function(h) { return h.price_per_kg; });
      var stores = history.map(function(h) { return h.store || ''; });
      new Chart(document.getElementById('priceChart'), {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Price / kg',
            data: prices,
            borderColor: brand,
            backgroundColor: 'rgba(47, 107, 79, 0.1)',
            pointBackgroundColor: accent,
            pointRadius: 5,
            tension: 0.2,
            fill: true
          }]
        },
        options: {
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                afterBody: function(ctx) {
                  var i = ctx[0].dataIndex;
                  return stores[i] ? 'Store: ' + stores[i] : '';
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              ticks: {
                callback: function(v) {
                  return '{{ (ing.currency or "USD") | csym }}' + v.toFixed(2);
                }
              }
            }
          }
        }
      });
    })();
    </script>
    {% endif %}
    {% endif %}
  </section>
</div>
{% endblock %}

{% extends "base.html.j2" %}

{% block title %}{{ recipe.name }}{% endblock %}

{% set csym = nutrition.currency | csym %}
{% set srv = nutrition.serving_scale %}

{% block page_intro %}
<section class="hero hero--recipe">
  <div class="hero__copy surface-card">
    {% if show_nav %}
    <a class="back-link" href="{{ base }}">&larr; Back to the recipe browser</a>
    {% endif %}
    <p class="eyebrow">Recipe sheet</p>
    <h1 class="hero__title hero__title--tight">{{ recipe.name }}</h1>
    <p class="hero__lead">
      Exact ingredient weights, crisp instructions, and computed nutrition in a layout built for cooking,
      printing, and scanning quickly.
    </p>
    <div class="chip-row">
      <span class="chip chip--strong">Serves {{ recipe.serves }}</span>
      <span class="chip chip--soft">Serving size {{ nutrition.grams_per_serving }} g</span>
      {% for tag in recipe.tags %}
        <span class="chip">{{ tag }}</span>
      {% endfor %}
    </div>
  </div>
  <aside class="hero__rail surface-card surface-card--accent">
    <p class="eyebrow eyebrow--soft">Per serving</p>
    <div class="metric-grid">
      <article class="metric-card">
        <span class="metric-card__label">Calories</span>
        <strong>{{ (nutrition.calories * srv) | round(1) }} kcal</strong>
      </article>
      <article class="metric-card">
        <span class="metric-card__label">Protein</span>
        <strong>{{ (nutrition.protein * srv) | round(1) }} g</strong>
      </article>
      <article class="metric-card">
        <span class="metric-card__label">Carbs</span>
        <strong>{{ (nutrition.carbs * srv) | round(1) }} g</strong>
      </article>
      <article class="metric-card">
        <span class="metric-card__label">Cost</span>
        <strong>{{ csym }}{{ "%.2f"|format(nutrition.cost * srv) }}</strong>
      </article>
    </div>
    <p class="hero-note">
      The nutrition panel and cost breakdown stay attached to the recipe so you can cook and audit in one pass.
    </p>
  </aside>
</section>
{% endblock %}

{% block content %}
{% set dv = {
  'calories': 2000, 'fat': 78, 'saturated_fat': 20, 'cholesterol_mg': 300,
  'sodium_mg': 2300, 'carbs': 275, 'fiber': 28, 'sugar': 50, 'protein': 50,
  'potassium_mg': 4700, 'calcium_mg': 1300, 'iron_mg': 18, 'magnesium_mg': 420,
  'manganese_mg': 2.3, 'vitamin_c_mg': 90, 'vitamin_d_mcg': 20, 'vitamin_k_mcg': 120
} %}
<div class="recipe-layout">
  <div class="recipe-stack">
    <section class="panel-card surface-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Ingredients</p>
          <h2 class="section-heading">Everything measured and ready.</h2>
        </div>
      </div>
      {% set has_groups = recipe.ingredients | selectattr('group', 'defined') | list | length > 0 %}
      <div class="table-shell">
        <table class="data-table">
          <thead>
            <tr><th>Ingredient</th><th class="align-right">Amount</th><th>Unit</th><th>Notes</th></tr>
          </thead>
          <tbody>
            {% if has_groups %}
              {% for item in recipe.ingredients %}
                {% if item.group is defined %}
                <tr class="group-row"><td colspan="4">{{ item.group }}</td></tr>
                {% for ing in item.items %}
                <tr>
                  <td class="indent">{{ ing.name }}{% if ing.optional %} <span class="optional">optional</span>{% endif %}</td>
                  <td class="align-right mono">{{ ing.amount }}</td>
                  <td>{{ ing.unit }}</td>
                  <td class="subtle">{{ ing.note }}</td>
                </tr>
                {% endfor %}
                {% endif %}
              {% endfor %}
            {% else %}
              {% for ing in recipe.ingredients %}
              <tr>
                <td>{{ ing.name }}{% if ing.optional %} <span class="optional">optional</span>{% endif %}</td>
                <td class="align-right mono">{{ ing.amount }}</td>
                <td>{{ ing.unit }}</td>
                <td class="subtle">{{ ing.note }}</td>
              </tr>
              {% endfor %}
            {% endif %}
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel-card surface-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Method</p>
          <h2 class="section-heading">Cook it in order.</h2>
        </div>
      </div>
      {% set ns = namespace(n=1) %}
      {% for item in recipe.instructions %}
        <div class="step-group">
          {% if item.section is defined %}
          <h3 class="step-group__title">{{ item.section }}</h3>
          <ol class="step-list" start="{{ ns.n }}">
            {% for step in item.steps %}
            <li>{{ step }}</li>
            {% set ns.n = ns.n + 1 %}
            {% endfor %}
          </ol>
          {% else %}
          <ol class="step-list" start="{{ ns.n }}">
            <li>{{ item }}</li>
          </ol>
          {% set ns.n = ns.n + 1 %}
          {% endif %}
        </div>
      {% endfor %}
    </section>

    {% if recipe.notes %}
    <section class="panel-card surface-card">
      <div class="panel-card__header">
        <div>
          <p class="eyebrow">Notes</p>
          <h2 class="section-heading">Kitchen context worth keeping.</h2>
        </div>
      </div>
      <div class="note-block">{{ recipe.notes | notes_html }}</div>
    </section>
    {% endif %}
  </div>

  <aside>
    <div class="nutrition-card">
      <span class="nutrition-card__kicker">Daily view</span>
      <h3>Cost</h3>
      <table class="nutrition-table">
      {% for item in nutrition.cost_breakdown %}
      <tr><td>{{ item.name }}</td><td>{{ csym }}{{ "%.2f"|format(item.cost) }}</td></tr>
      {% endfor %}
      <tr class="major"><td>Total recipe</td><td>{{ csym }}{{ "%.2f"|format(nutrition.cost) }}</td></tr>
      <tr><td>Per serving</td><td>{{ csym }}{{ "%.2f"|format(nutrition.cost * srv) }}</td></tr>
      </table>
    </div>

    <div class="nutrition-card">
      <span class="nutrition-card__kicker">Per serving</span>
      <h3>Macros</h3>
      <p class="subtle">Based on a 2,000 kcal diet and {{ nutrition.grams_per_serving }} g serving size.</p>
      <table class="nutrition-table">
      <tr class="major"><td>Calories</td><td>{{ (nutrition.calories * srv) | round(1) }} kcal</td><td class="dv">{{ (nutrition.calories * srv / dv.calories * 100) | round | int }}%</td></tr>
      <tr><td>Protein</td><td>{{ (nutrition.protein * srv) | round(1) }} g</td><td class="dv">{{ (nutrition.protein * srv / dv.protein * 100) | round | int }}%</td></tr>
      <tr><td>Total Fat</td><td>{{ (nutrition.fat * srv) | round(1) }} g</td><td class="dv">{{ (nutrition.fat * srv / dv.fat * 100) | round | int }}%</td></tr>
      {% if nutrition.saturated_fat %}<tr class="sub"><td>Saturated Fat</td><td>{{ (nutrition.saturated_fat * srv) | round(1) }} g</td><td class="dv">{{ (nutrition.saturated_fat * srv / dv.saturated_fat * 100) | round | int }}%</td></tr>{% endif %}
      <tr><td>Total Carbohydrate</td><td>{{ (nutrition.carbs * srv) | round(1) }} g</td><td class="dv">{{ (nutrition.carbs * srv / dv.carbs * 100) | round | int }}%</td></tr>
      {% if nutrition.fiber %}<tr class="sub"><td>Dietary Fiber</td><td>{{ (nutrition.fiber * srv) | round(1) }} g</td><td class="dv">{{ (nutrition.fiber * srv / dv.fiber * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.sugar %}<tr class="sub"><td>Total Sugars</td><td>{{ (nutrition.sugar * srv) | round(1) }} g</td><td class="dv">{{ (nutrition.sugar * srv / dv.sugar * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.cholesterol_mg %}<tr><td>Cholesterol</td><td>{{ (nutrition.cholesterol_mg * srv) | round(1) }} mg</td><td class="dv">{{ (nutrition.cholesterol_mg * srv / dv.cholesterol_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.sodium_mg %}<tr><td>Sodium</td><td>{{ (nutrition.sodium_mg * srv) | round(1) }} mg</td><td class="dv">{{ (nutrition.sodium_mg * srv / dv.sodium_mg * 100) | round | int }}%</td></tr>{% endif %}
      </table>
    </div>

    {% if nutrition.potassium_mg or nutrition.calcium_mg or nutrition.iron_mg or nutrition.magnesium_mg or nutrition.manganese_mg or nutrition.vitamin_c_mg or nutrition.vitamin_d_mcg or nutrition.vitamin_k_mcg %}
    <div class="nutrition-card">
      <span class="nutrition-card__kicker">Micronutrients</span>
      <h3>Vitamins and minerals</h3>
      <table class="nutrition-table">
      {% if nutrition.potassium_mg %}<tr><td>Potassium</td><td>{{ (nutrition.potassium_mg * srv) | round(1) }} mg</td><td class="dv">{{ (nutrition.potassium_mg * srv / dv.potassium_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.calcium_mg %}<tr><td>Calcium</td><td>{{ (nutrition.calcium_mg * srv) | round(1) }} mg</td><td class="dv">{{ (nutrition.calcium_mg * srv / dv.calcium_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.iron_mg %}<tr><td>Iron</td><td>{{ (nutrition.iron_mg * srv) | round(2) }} mg</td><td class="dv">{{ (nutrition.iron_mg * srv / dv.iron_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.magnesium_mg %}<tr><td>Magnesium</td><td>{{ (nutrition.magnesium_mg * srv) | round(1) }} mg</td><td class="dv">{{ (nutrition.magnesium_mg * srv / dv.magnesium_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.manganese_mg %}<tr><td>Manganese</td><td>{{ (nutrition.manganese_mg * srv) | round(3) }} mg</td><td class="dv">{{ (nutrition.manganese_mg * srv / dv.manganese_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.vitamin_c_mg %}<tr><td>Vitamin C</td><td>{{ (nutrition.vitamin_c_mg * srv) | round(2) }} mg</td><td class="dv">{{ (nutrition.vitamin_c_mg * srv / dv.vitamin_c_mg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.vitamin_d_mcg %}<tr><td>Vitamin D</td><td>{{ (nutrition.vitamin_d_mcg * srv) | round(2) }} mcg</td><td class="dv">{{ (nutrition.vitamin_d_mcg * srv / dv.vitamin_d_mcg * 100) | round | int }}%</td></tr>{% endif %}
      {% if nutrition.vitamin_k_mcg %}<tr><td>Vitamin K</td><td>{{ (nutrition.vitamin_k_mcg * srv) | round(2) }} mcg</td><td class="dv">{{ (nutrition.vitamin_k_mcg * srv / dv.vitamin_k_mcg * 100) | round | int }}%</td></tr>{% endif %}
      </table>
    </div>
    {% endif %}

    {% if nutrition.missing_ingredients %}
    <div class="nutrition-card warning-card">
      <span class="nutrition-card__kicker">Catalog warning</span>
      <h3>Missing ingredient data</h3>
      <p class="subtle">{{ nutrition.missing_ingredients | join(", ") }}</p>
    </div>
    {% endif %}
  </aside>
</div>

{% if debug %}
<section class="panel-card surface-card" style="margin-top:1.2rem">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Debug panel</p>
      <h2 class="section-heading debug-heading">Nutrition breakdown by ingredient.</h2>
    </div>
  </div>
  <p class="subtle">Total recipe values, useful when auditing catalog accuracy or ingredient conversions.</p>
  <div class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Ingredient</th><th class="align-right">g</th><th class="align-right">Cost</th>
          <th class="align-right">Cal</th><th class="align-right">Protein</th><th class="align-right">Carbs</th><th class="align-right">Fat</th><th class="align-right">Sat. fat</th>
          <th class="align-right">Fiber</th><th class="align-right">Sugar</th><th class="align-right">Sodium mg</th><th class="align-right">Chol mg</th>
          <th class="align-right">Calcium mg</th><th class="align-right">Iron mg</th><th class="align-right">Potassium mg</th><th class="align-right">Mag. mg</th>
        </tr>
      </thead>
      <tbody>
      {% for i in nutrition.ingredient_breakdown %}
      <tr>
        <td>{{ i.name }}</td>
        <td class="align-right mono">{{ i.grams }}</td>
        <td class="align-right mono">{% if i.cost is not none %}{{ csym }}{{ "%.2f"|format(i.cost) }}{% else %}-{% endif %}</td>
        <td class="align-right mono">{{ i.calories }}</td><td class="align-right mono">{{ i.protein }}</td><td class="align-right mono">{{ i.carbs }}</td><td class="align-right mono">{{ i.fat }}</td>
        <td class="align-right mono">{{ i.saturated_fat }}</td><td class="align-right mono">{{ i.fiber }}</td><td class="align-right mono">{{ i.sugar }}</td>
        <td class="align-right mono">{{ i.sodium_mg }}</td>
        <td class="align-right mono">{{ i.cholesterol_mg }}</td>
        <td class="align-right mono">{{ i.calcium_mg }}</td><td class="align-right mono">{{ i.iron_mg }}</td><td class="align-right mono">{{ i.potassium_mg }}</td><td class="align-right mono">{{ i.magnesium_mg }}</td>
      </tr>
      {% endfor %}
      <tr class="group-row">
        <td>Total</td><td class="align-right mono">-</td>
        <td class="align-right mono">{{ csym }}{{ "%.2f"|format(nutrition.cost) }}</td>
        <td class="align-right mono">{{ nutrition.calories }}</td><td class="align-right mono">{{ nutrition.protein }}</td><td class="align-right mono">{{ nutrition.carbs }}</td><td class="align-right mono">{{ nutrition.fat }}</td>
        <td class="align-right mono">{{ nutrition.saturated_fat }}</td><td class="align-right mono">{{ nutrition.fiber }}</td><td class="align-right mono">{{ nutrition.sugar }}</td>
        <td class="align-right mono">{{ nutrition.sodium_mg }}</td><td class="align-right mono">{{ nutrition.cholesterol_mg }}</td>
        <td class="align-right mono">{{ nutrition.calcium_mg }}</td><td class="align-right mono">{{ nutrition.iron_mg }}</td><td class="align-right mono">{{ nutrition.potassium_mg }}</td><td class="align-right mono">{{ nutrition.magnesium_mg }}</td>
      </tr>
      </tbody>
    </table>
  </div>
  {% if nutrition.missing_ingredients %}
  <p class="subtle" style="margin-top:0.8rem">Excluded from totals because they are missing catalog data: {{ nutrition.missing_ingredients | join(", ") }}</p>
  {% endif %}
</section>
{% endif %}
{% endblock %}

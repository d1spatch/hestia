{% extends "base.html.j2" %}

{% block title %}Ingredients{% endblock %}

{% block content %}
<h1>Ingredient Catalog</h1>

<form class="search-bar" method="get" action="{{ base }}ingredients/"{% if static %} onsubmit="return false"{% endif %}>
  <input id="ing-q" name="q" value="{{ q }}" placeholder="Search ingredients…">
  <button type="submit">Search</button>
  {% if q %}
    <a class="clear-link" href="{{ base }}ingredients/">Clear</a>
  {% endif %}
</form>

{% if not ingredients %}
  <p class="no-results">No ingredients match your search.</p>
{% else %}
<table class="ing-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th class="r">kcal / 100g</th>
      <th class="r">Protein</th>
      <th class="r">Carbs</th>
      <th class="r">Fat</th>
      <th class="r">Price / kg</th>
    </tr>
  </thead>
  <tbody>
    {% for ing in ingredients %}
    <tr class="ing-row" data-name="{{ ing.name | lower }}">
      <td class="name-cell">
        <a href="{{ base }}ingredient/{{ ing.name | url_encode }}/" class="ing-link">{{ ing.name }}</a>
      </td>
      <td class="cat">{{ ing.category or '—' }}</td>
      <td class="r num">
        {% if ing.calories_per_100g is defined and ing.calories_per_100g is not none %}{{ "%.0f"|format(ing.calories_per_100g) }}{% else %}—{% endif %}
      </td>
      <td class="r num">
        {% if ing.protein_per_100g is defined and ing.protein_per_100g is not none %}{{ "%.1f"|format(ing.protein_per_100g) }} g{% else %}—{% endif %}
      </td>
      <td class="r num">
        {% if ing.carbs_per_100g is defined and ing.carbs_per_100g is not none %}{{ "%.1f"|format(ing.carbs_per_100g) }} g{% else %}—{% endif %}
      </td>
      <td class="r num">
        {% if ing.fat_per_100g is defined and ing.fat_per_100g is not none %}{{ "%.1f"|format(ing.fat_per_100g) }} g{% else %}—{% endif %}
      </td>
      <td class="r num">
        {% if ing.price_per_kg is defined and ing.price_per_kg is not none %}{{ (ing.currency or 'USD') | csym }}{{ "%.2f"|format(ing.price_per_kg) }}{% else %}—{% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% if static %}
<script>
(function() {
  var input = document.getElementById('ing-q');
  function filter() {
    var q = input.value.toLowerCase().trim();
    document.querySelectorAll('.ing-row').forEach(function(row) {
      row.style.display = (!q || row.dataset.name.includes(q)) ? '' : 'none';
    });
  }
  input.addEventListener('input', filter);
})();
</script>
{% endif %}

<style>
.ing-table { width: 100%; border-collapse: collapse; font-size: 0.93rem; }
.ing-table th {
  text-align: left; border-bottom: 2px solid var(--border);
  padding: 0.4rem 0.7rem; color: var(--accent); font-size: 0.85rem;
  font-family: Georgia, serif; font-style: italic;
}
.ing-table th.r { text-align: right; }
.ing-table td { padding: 0.38rem 0.7rem; border-bottom: 1px solid var(--border); }
.ing-table tr:hover td { background: #e2ede0; }
.name-cell { font-weight: bold; }
.ing-link { color: var(--accent); text-decoration: none; }
.ing-link:hover { text-decoration: underline; }
.cat { color: var(--muted); font-size: 0.88rem; }
.r { text-align: right; }
.num { font-variant-numeric: tabular-nums; }
</style>
{% endblock %}

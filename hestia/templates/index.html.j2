{% extends "base.html.j2" %}

{% block title %}Recipes{% endblock %}

{% block page_intro %}
<section class="hero hero--home">
  <div class="hero__copy surface-card">
    <p class="eyebrow">Precision cookbook</p>
    <h1 class="hero__title">Cook from data without losing the feeling of a real kitchen.</h1>
    <p class="hero__lead">
      Hestia keeps exact weights, reusable ingredient data, nutrition, and cost inside a
      web interface that stays bright, calm, and easy to move through.
    </p>
    <div class="hero__actions">
      <a class="button" href="#recipe-grid">Browse recipes</a>
      <a class="button button--ghost" href="{{ base }}docs/quickstart/">Read the quickstart</a>
    </div>
  </div>
  <aside class="hero__rail surface-card surface-card--accent">
    <p class="eyebrow eyebrow--soft">At a glance</p>
    <div class="stat-grid">
      <article class="stat-card">
        <span class="stat-card__label">Recipes</span>
        <strong>{{ summary.recipe_count }}</strong>
        <p>Versionable dishes ready to browse.</p>
      </article>
      <article class="stat-card">
        <span class="stat-card__label">Tags</span>
        <strong>{{ summary.tag_count }}</strong>
        <p>Quick themes for baking, sides, sauces, and more.</p>
      </article>
      <article class="stat-card">
        <span class="stat-card__label">Ingredients</span>
        <strong>{{ summary.ingredient_count }}</strong>
        <p>Linked pantry intelligence across every recipe.</p>
      </article>
      <article class="stat-card">
        <span class="stat-card__label">Workflow</span>
        <strong>YAML</strong>
        <p>Plain text recipes that still render like a polished product.</p>
      </article>
    </div>
    <p class="hero-note">
      Search by dish, tag, or pantry item, then jump straight into cost and nutrition-aware recipe pages.
    </p>
  </aside>
</section>
{% endblock %}

{% block content %}
<section class="search-panel surface-card">
  <div class="search-panel__header">
    <div>
      <p class="eyebrow">Recipe finder</p>
      <h2 class="section-heading">Search the full cookbook.</h2>
    </div>
    <p class="search-panel__summary">
      <span id="results-count">{{ recipes | length }}</span> of {{ summary.recipe_count }} recipes visible
    </p>
  </div>

  <form method="get" action="{{ base }}"{% if static %} onsubmit="return false"{% endif %}>
    <div class="filter-grid">
      <label class="field">
        <span>Name</span>
        <input id="q-input" name="q" value="{{ q }}" placeholder="sourdough, salsa, cheesecake">
      </label>
      <label class="field">
        <span>Tag</span>
        <input id="tag-input" name="tag" value="{{ tag }}" placeholder="bread, banchan, dessert">
      </label>
      <label class="field">
        <span>Ingredient</span>
        <input id="ing-input" name="ingredient" value="{{ ingredient }}" placeholder="flour, habanero, cucumber">
      </label>
    </div>
    <div class="filter-actions">
      <button class="button" type="submit">Refine results</button>
      {% if q or tag or ingredient %}
        <a class="text-link" href="{{ base }}">Reset filters</a>
      {% endif %}
    </div>
  </form>
</section>

{% if not recipes %}
  <section class="surface-card empty-state" id="no-results">
    <p class="eyebrow">No matches yet</p>
    <h2 class="section-heading">No recipes matched this search.</h2>
    <p>Try a broader tag, part of an ingredient name, or clear the filters and start fresh.</p>
  </section>
{% else %}
  <section class="surface-card empty-state" id="no-results" style="display:none">
    <p class="eyebrow">No matches yet</p>
    <h2 class="section-heading">No recipes matched this search.</h2>
    <p>Try a broader tag, part of an ingredient name, or clear the filters and start fresh.</p>
  </section>
  <div class="recipe-grid" id="recipe-grid">
    {% for path, recipe in recipes %}
    {% set ing_names = [] %}
    {% for item in recipe.ingredients %}
      {% if item.items is defined %}
        {% for ing in item.items %}{% set _ = ing_names.append(ing.name) %}{% endfor %}
      {% else %}
        {% set _ = ing_names.append(item.name) %}
      {% endif %}
    {% endfor %}
    <article
      class="recipe-card"
      data-name="{{ recipe.name | lower }}"
      data-tags="{{ recipe.tags | join(',') | lower }}"
      data-ingredients="{{ ing_names | join(',') | lower }}"
    >
      <div class="recipe-card__meta">
        <span>Serves {{ recipe.serves }}</span>
        <span>&middot;</span>
        <span>{{ ing_names | length }} ingredients</span>
      </div>
      <a class="recipe-card__title" href="{{ base }}recipe/{{ recipe.slug }}/">{{ recipe.name }}</a>
      <div class="recipe-card__body">
        {% if recipe.tags %}
        <div class="chip-row">
          {% for t in recipe.tags %}
            <span class="chip">{{ t }}</span>
          {% endfor %}
        </div>
        {% endif %}
        <p class="recipe-card__ingredients">{{ ing_names | join(', ') }}</p>
      </div>
      <div class="recipe-card__footer">
        <a class="text-link" href="{{ base }}recipe/{{ recipe.slug }}/">Open recipe</a>
        <span>Nutrition-aware detail view</span>
      </div>
    </article>
    {% endfor %}
  </div>
{% endif %}

{% if static %}
<script>
(function() {
  var qInput = document.getElementById('q-input');
  var tagInput = document.getElementById('tag-input');
  var ingInput = document.getElementById('ing-input');
  var noRes = document.getElementById('no-results');
  var results = document.getElementById('results-count');

  function filter() {
    var q = qInput.value.toLowerCase().trim();
    var tag = tagInput.value.toLowerCase().trim();
    var ing = ingInput.value.toLowerCase().trim();
    var cards = document.querySelectorAll('.recipe-card');
    var shown = 0;
    cards.forEach(function(card) {
      var match =
        (!q || card.dataset.name.includes(q)) &&
        (!tag || card.dataset.tags.split(',').some(function(t) { return t.trim().includes(tag); })) &&
        (!ing || card.dataset.ingredients.split(',').some(function(i) { return i.trim().includes(ing); }));
      card.style.display = match ? '' : 'none';
      if (match) {
        shown++;
      }
    });
    noRes.style.display = shown === 0 ? '' : 'none';
    if (results) {
      results.textContent = String(shown);
    }
  }

  [qInput, tagInput, ingInput].forEach(function(el) {
    el.addEventListener('input', filter);
  });
})();
</script>
{% endif %}
{% endblock %}

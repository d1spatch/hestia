:root {
  color-scheme: light;
  --font-display: "Aptos Display", "Segoe UI", "Trebuchet MS", sans-serif;
  --font-sans: "Aptos", "Segoe UI", "Calibri", sans-serif;
  --font-serif: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
  --font-mono: "Cascadia Code", "Consolas", "Courier New", monospace;
  --page-bg: #f4efe6;
  --page-bg-soft: #fbf7f1;
  --page-bg-contrast: #eef5ee;
  --surface: rgba(255, 251, 245, 0.82);
  --surface-strong: #fffdf9;
  --surface-muted: rgba(236, 244, 236, 0.86);
  --line: rgba(86, 108, 95, 0.18);
  --line-strong: rgba(47, 107, 79, 0.26);
  --text: #203127;
  --muted: #607264;
  --brand: #2f6b4f;
  --brand-strong: #1f553d;
  --brand-soft: #dcecdc;
  --accent: #cf7d57;
  --accent-soft: #f7e0d2;
  --sun: #d3b46a;
  --shadow-soft: 0 18px 40px rgba(28, 47, 38, 0.08);
  --shadow-strong: 0 28px 72px rgba(28, 47, 38, 0.12);
  --radius-xl: 32px;
  --radius-lg: 24px;
  --radius-md: 18px;
  --radius-sm: 12px;
  --content-width: 1180px;
  --transition: 220ms ease;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: var(--font-sans);
  color: var(--text);
  background:
    radial-gradient(circle at top left, rgba(211, 180, 106, 0.16), transparent 34rem),
    radial-gradient(circle at 82% 12%, rgba(220, 236, 220, 0.92), transparent 26rem),
    linear-gradient(180deg, var(--page-bg-soft), var(--page-bg));
  line-height: 1.65;
}

body::selection,
body *::selection {
  background: rgba(47, 107, 79, 0.18);
}

img,
svg,
canvas {
  display: block;
  max-width: 100%;
}

a {
  color: var(--brand-strong);
  text-decoration: none;
  transition:
    color var(--transition),
    transform var(--transition),
    border-color var(--transition),
    background-color var(--transition);
}

a:hover {
  color: var(--accent);
}

button,
input,
textarea,
select {
  font: inherit;
}

code,
kbd,
pre {
  font-family: var(--font-mono);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin: 0 0 1rem;
  color: var(--brand-strong);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.eyebrow::before {
  content: "";
  width: 0.8rem;
  height: 0.8rem;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--sun), var(--accent));
  box-shadow: 0 0 0 0.35rem rgba(207, 125, 87, 0.12);
}

.eyebrow--soft {
  color: rgba(32, 49, 39, 0.82);
}

.section-heading {
  margin: 0;
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 2.4vw, 2.2rem);
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--brand-strong);
}

.surface-card {
  position: relative;
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  background: var(--surface);
  backdrop-filter: blur(18px);
  box-shadow: var(--shadow-soft);
}

.surface-card--accent {
  background:
    linear-gradient(180deg, rgba(255, 248, 241, 0.98), rgba(245, 237, 225, 0.92));
  border-color: rgba(207, 125, 87, 0.2);
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.55rem;
  padding: 0.95rem 1.35rem;
  border-radius: 999px;
  border: 1px solid transparent;
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
  font-weight: 700;
  letter-spacing: 0.01em;
  box-shadow: 0 14px 28px rgba(47, 107, 79, 0.18);
}

.button:hover {
  color: #fff;
  transform: translateY(-1px);
  box-shadow: 0 18px 32px rgba(47, 107, 79, 0.22);
}

.button--ghost {
  background: rgba(255, 255, 255, 0.55);
  color: var(--brand-strong);
  border-color: var(--line-strong);
  box-shadow: none;
}

.button--ghost:hover {
  color: var(--brand-strong);
  background: rgba(255, 255, 255, 0.82);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.42rem 0.72rem;
  border-radius: 999px;
  background: rgba(47, 107, 79, 0.1);
  color: var(--brand-strong);
  font-size: 0.84rem;
  font-weight: 700;
}

.chip--strong {
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
}

.chip--soft {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid var(--line);
  color: var(--muted);
}

.muted-text {
  color: var(--muted);
}
